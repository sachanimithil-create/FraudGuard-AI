import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

import warnings
warnings.filterwarnings("ignore")


df= pd.read_csv('/FraudGuard-AI/data/raw/creditcard.csv')


# Transaction Amount Distribution
plt.figure(figsize=(10,5))

sns.histplot(df["Amount"], bins=50, kde=True)

plt.title("Distribution of Transaction Amount")
plt.xlabel("Amount")
plt.ylabel("Frequency")

plt.show()


# Transaction Time Distribution
plt.figure(figsize=(10,5))

sns.histplot(df["Time"], bins=50)

plt.title("Transaction Time Distribution")

plt.show()


# Class Distribution
plt.figure(figsize=(6,4))

sns.countplot(x="Class", data=df)

plt.title("Fraud vs Genuine Transactions")

plt.show()


# Fraud Percentage
fraud_percentage = df["Class"].value_counts(normalize=True) * 100

print(fraud_percentage)


# Amount Distribution by Class
plt.figure(figsize=(10,5))

sns.boxplot(x="Class", y="Amount", data=df)

plt.title("Transaction Amount by Class")

plt.show()


# Statistics by Class

df.groupby("Class")["Amount"].describe()


# Correlation Matrix

corr = df.corr()

plt.figure(figsize=(20,15))

sns.heatmap(corr,
            cmap="coolwarm",
            center=0)

plt.title("Correlation Matrix")

plt.show()


# Correlation with Target

corr_target = df.corr()["Class"].sort_values(ascending=False)

print(corr_target)


# Pair Plot

sample_df = df.sample(1000, random_state=42)

sns.pairplot(sample_df[["V1","V2","V3","Amount","Class"]],
             hue="Class")

plt.show()


# Amount Outliers

plt.figure(figsize=(10,5))

sns.boxplot(x=df["Amount"])

plt.title("Amount Outliers")

plt.show()


# Time Outliers

plt.figure(figsize=(10,5))

sns.boxplot(x=df["Time"])

plt.title("Time Distribution")

plt.show()


print("="*50)
print("EDA SUMMARY")
print("="*50)

print("1. Dataset is highly imbalanced.")
print("2. Fraud transactions are very rare.")
print("3. Amount is highly skewed.")
print("4. No missing values.")
print("5. Time and Amount require scaling.")
print("6. Features V1-V28 are already PCA-transformed.")
print("7. SMOTE will be applied during preprocessing.")



